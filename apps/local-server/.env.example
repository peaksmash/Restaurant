LAST_TOKEN=put_your_last_token_here

# Controla el modo de impresión de comandas.
# disabled (por defecto): no usa impresora real; crea print_job con estado failed/controlado y mensaje claro.
# browser:                 genera SVG/HTML imprimible que el navegador puede imprimir con window.print().
# No hay driver de impresora hardware todavía. Usar "browser" para pruebas manuales.
PRINTER_MODE=disabled

