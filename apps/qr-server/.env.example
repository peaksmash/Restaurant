# qr-server environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Server
# Local only. In Render, DO NOT create a PORT env var manually.
PORT=3005

# Comma-separated list of frontend origins allowed by CORS.
# Dev:  http://localhost:3003
# Prod: https://<your-cloudflare-pages-project>.pages.dev,https://<your-domain>
ALLOWED_ORIGINS=http://localhost:3003

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key as a single line with \n (not literal newlines).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Last.app
LAST_TOKEN=your-last-app-bearer-token
LAST_BASE_URL=https://api.last.app/v2

# Render deploy notes:
# - Build: npm install && npm run build --workspace apps/qr-server
# - Start: npm run start --workspace apps/qr-server
# - Health check: /health
# - Seed is manual only when needed:
#   npm run seed:tenant --workspace apps/qr-server

# Future: Stripe (not yet active)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
