# qr-pedidos environment variables
# Copy this file to .env (or .env.local for Vite) and fill in real values.
# NEVER commit .env to git.

# qr-server connection
# Dev:  http://localhost:3005
# Prod: https://<your-render-service>.onrender.com
VITE_QR_SERVER_URL=http://localhost:3005

# Tenant slug (derived from Last.app org name via seed:tenant script)
VITE_QR_SERVER_TENANT=jose-ranea-location

# Location key (derived from Last.app location name via seed:tenant script)
VITE_QR_SERVER_LOCATION_KEY=jose-ranea-location

# Google Maps / Places
# Required for delivery address autocomplete and map pin.
# Leave empty to fall back to manual input + geolocation button.
# In Google Cloud Console, restrict this key to your Cloudflare Pages domain
# and to your final custom domain when it exists.
VITE_GOOGLE_MAPS_API_KEY=

# Cloudflare Pages deploy notes:
# - Root directory: apps/qr-pedidos
# - Build command: npm run build
# - Output directory: dist
