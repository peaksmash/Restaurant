# Backend (local-server)
PORT=3001
DATABASE_PATH=./data/local-server.sqlite

# Example for default Vite ports 5173-5176:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
#
# Current repo scripts use:
# - kiosk-web  -> http://localhost:3000
# - admin-web  -> http://localhost:3002
# - qr-order   -> http://localhost:3003
# - orders     -> http://localhost:3004
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004

# Last
# Current backend reads LAST_TOKEN.
# The IDs below are normally configured from Admin/setup and persisted in SQLite.
LAST_TOKEN=
LAST_API_TOKEN=
LAST_ORGANIZATION_ID=
LAST_LOCATION_ID=
LAST_BRAND_ID=
LAST_CATALOG_ID=

# Payments / printing
# true = no real money is charged
PAYMENTS_DEMO_MODE=true
# disabled = fail with "Impresora no configurada"
# browser  = return printable browser preview
PRINTER_MODE=browser

# Artemis future test inventory (not active in code yet)
ARTEMIS_TEST_BASE_URL=
ARTEMIS_TEST_API_KEY=
ARTEMIS_OWNER=

# Frontends
# Vite env vars are loaded per app. Copy this value into:
# - apps/admin-web/.env.local
# - apps/kiosk-web/.env.local
# - apps/orders/.env.local
# - apps/qr-order/.env.local
VITE_API_BASE_URL=http://localhost:3001
